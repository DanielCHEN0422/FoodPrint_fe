# Metro
.metro-health-check*

# Lock files（保留 pnpm-lock.yaml 提交，忽略其他包管理器的）
package-lock.json
yarn.lock
bun.lock

# 环境变量与密钥（勿提交）
.env
.env.*
!.env.example

# Debug / 日志
npm-debug.*
yarn-debug.*
yarn-error.*
*.log
logs/

# TypeScript
*.tsbuildinfo

# 测试 / 覆盖率
coverage/
.nyc_output/

# 编辑器 / 系统
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/
*.swp
*.swo
*~

