# 复制为 .env 并填入真实值（.env 已加入 .gitignore，不会提交）
# Expo 使用 EXPO_PUBLIC_ 前缀的变量会在构建时注入客户端，未加前缀的仅在 Node 环境可用

# Supabase（必填，用于登录注册与后端 API JWT）
EXPO_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 后端 Spring Boot API 根地址。真机/模拟器请用电脑局域网 IP，例如 http://192.168.1.x:8080
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
